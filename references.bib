 doi = {10.17192/bfdm.2020.2.8281},
 file = {WOLF20{\_}sschulte, Beitrag{\_}Wolf:Attachments/WOLF20{\_}sschulte, Beitrag{\_}Wolf.pdf:application/pdf}
}


